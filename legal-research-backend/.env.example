# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Intake email (optional — https://resend.com)
RESEND_API_KEY=re_your_resend_key_here
INTAKE_NOTIFY_EMAIL=sales@owl-ai-agency.com
INTAKE_FROM_EMAIL=OWL Legal Research <onboarding@resend.dev>
NURTURE_FROM_EMAIL=OWL Legal Research <onboarding@resend.dev>

# GEO agent (optional — https://www.indexnow.org/)
INDEXNOW_KEY=your_indexnow_key_here
GEO_GSC_DAILY_URL_LIMIT=8

# Cloudflare — owl-ai-agency.com (https://dash.cloudflare.com)
# Account ID: Dashboard → right sidebar on any zone overview
# Zone ID: Dashboard → owl-ai-agency.com → Overview → API section (right column)
# API Token (recommended): My Profile → API Tokens → Create Token
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here
CLOUDFLARE_ZONE_ID=your_owl_ai_agency_zone_id_here
CLOUDFLARE_ZONE_NAME=owl-ai-agency.com
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
# Legacy global API key (optional — use token above instead when possible)
CLOUDFLARE_API_KEY=your_cloudflare_global_api_key_here
CLOUDFLARE_API_EMAIL=your_cloudflare_account_email_here

# Render / CORS
ALLOWED_ORIGINS=https://owl-ai-agency.com,https://hobie1kenobi.github.io,http://localhost:5500
PYTHON_VERSION=3.11.11

# Zoho Mail — outreach agent (app password, not OAuth)
# Zoho Mail → Settings → Security → App Passwords → generate for "OWL Outreach"
ZOHO_FROM_EMAIL=hobiecunningham@owl-ai-agency.com
ZOHO_USER_ID=696085898
ZOHO_APP_PASSWORD=your_zoho_app_password_here
ZOHO_SMTP_HOST=smtp.zoho.com
ZOHO_SMTP_PORT=587
